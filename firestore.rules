rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Archival Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // User Identity Sector
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             (data.lastLogin == request.time || data.lastLogin == null);
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; 
      allow create, update: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
    }

    // Entity Verifiers
    function isValidReview(data) {
      return data.productId is string && data.productId.size() <= 64 &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 128 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.createdAt == request.time;
    }

    // 1. Review Manifest Sector
    match /reviews/{reviewId} {
      allow read: if true; // Social proof is public manifestation
      
      allow create: if isSignedIn() && 
                      isValidId(reviewId) && 
                      isValidReview(incoming());
                      
      allow update: if false; // Reviews are immortal archival records
      
      allow delete: if isSignedIn() && (
                      existing().userId == request.auth.uid ||
                      exists(/databases/$(database)/documents/admins/$(request.auth.uid))
                    );
    }

    // 2. Order Manifest Sector
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
                      resource.data.userId == request.auth.uid ||
                      resource.data.email == request.auth.token.email
                    );
      
      allow create: if isSignedIn() && 
                      isValidId(orderId) &&
                      request.resource.data.email == request.auth.token.email &&
                      request.resource.data.createdAt == request.time;

      allow update, delete: if false; // Orders are immutable archival records
    }
  }
}
