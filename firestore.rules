rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- SHARED HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- HELPER WRAPPERS ---
    function isCreate() { return request.method == 'create'; }
    function isUpdate() { return request.method == 'update'; }
    function isWrite() { return isCreate() || isUpdate(); }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'prithvi2698@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    // --- ENTITY VALIDATIONS ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.productId is string && data.productId.size() <= 128 &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 128 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             (isCreate() ? data.createdAt == request.time : true);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['email', 'total', 'status', 'items', 'createdAt']) &&
             data.email is string && data.email.size() <= 256 &&
             data.total is number && data.total >= 0 &&
             data.status in ['PENDING_DISPATCH', 'SHIPPED', 'DELIVERED', 'CANCELLED'] &&
             data.items is list && data.items.size() > 0 &&
             (isCreate() ? data.createdAt == request.time : true);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'description', 'image', 'category', 'stock']) &&
             data.name is string && data.name.size() <= 256 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() <= 5000 &&
             data.image is string && data.image.size() <= 1000 &&
             data.category is string && data.category.size() <= 100 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidCart(data) {
      return data.keys().hasAll(['items', 'updatedAt']) &&
             data.items is list && data.items.size() <= 50 &&
             (isWrite() ? data.updatedAt == request.time : true);
    }

    // --- MATCH BLOCKS ---

    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
      )) || isAdmin();

      // CART SUBCOLLECTION
      match /cart/{cartId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if (isOwner(userId) && isValidCart(incoming())) || isAdmin();
      }
    }

    // PRODUCTS COLLECTION
    match /products/{productId} {
      allow list, get: if true;
      allow create, update, delete: if isAdmin() && isValidProduct(incoming());
    }

    // REVIEWS COLLECTION
    match /reviews/{reviewId} {
      allow list, get: if true;
      allow create: if isSignedIn() && isValidReview(incoming());
      allow update: if (isOwner(existing().userId) || isAdmin()) && isValidReview(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment'])
      );
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // ORDERS COLLECTION
    match /orders/{orderId} {
      // Users can see their own orders. Admin sees all.
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      // Orders are created either by signed in user or by guest if the app allows (here we expect uid if available)
      allow create: if (isSignedIn() && incoming().userId == request.auth.uid || !incoming().keys().hasAny(['userId'])) && isValidOrder(incoming());
      
      // Only admin can update order status
      allow update: if isAdmin() && isValidOrder(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])
      );
      
      allow delete: if isAdmin();
    }
    
    // ADMINS COLLECTION (INTERNAL)
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow write: if false; // Managed via server/console
    }
  }
}
