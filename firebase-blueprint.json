{
  "entities": {
    "Review": {
      "title": "Product Review",
      "description": "Engaged feedback manifest for a specific archival product.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Unique identifier for the product." },
        "userId": { "type": "string", "description": "Unique identifier for the dispatcher/operator." },
        "userName": { "type": "string", "description": "Display alias of the dispatcher." },
        "rating": { "type": "number", "description": "Engagement level synchronized from 1-5." },
        "comment": { "type": "string", "description": "Detailed archival feedback." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of initial synchronization." }
      },
      "required": ["productId", "userId", "userName", "rating", "comment", "createdAt"]
    },
    "Order": {
      "title": "Dispatch Order",
      "description": "Secured acquisition manifest for archival products.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "shipping": { "type": "object" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "items", "total", "shipping", "status", "createdAt"]
    },
    "User": {
      "title": "Operator Profile",
      "description": "Archival identity manifest for cross-sector synchronization.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Global identity manifest for all archival operators."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Global archival manifest for all product engagement data."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Secured manifest of all successful product acquisitions."
    }
  }
}
