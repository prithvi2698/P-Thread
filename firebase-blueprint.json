{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating", "comment", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "total": { "type": "number" },
        "shippingAmount": { "type": "number" },
        "paymentId": { "type": "string" },
        "status": { 
          "type": "string",
          "enum": ["PENDING_DISPATCH", "SHIPPED", "DELIVERED", "CANCELLED"]
        },
        "shippingDetails": { "type": "object" },
        "items": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "total", "status", "items", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Store product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "images": { "type": "array" },
        "sizes": { "type": "array" },
        "colors": { "type": "array" },
        "stock": { "type": "number" },
        "isNew": { "type": "boolean" },
        "isArchived": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "description", "image", "category", "stock"]
    },
    "Cart": {
      "title": "Cart",
      "description": "User shopping cart",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "users/{userId}/cart": {
      "schema": "Cart",
      "description": "User cart storage"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Store products"
    }
  }
}
